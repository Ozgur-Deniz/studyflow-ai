// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations 
  studyPlans    StudyPlan[]
  sessions      StudySession[]
  conversations Conversation[]
  achievements  Achievement[]
}

model StudyPlan {
  id          String   @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  
  // User Relation
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudySession {
  id          String   @id @default(cuid())
  duration    Float    // Toplam çalışma saati (örn: 1.5 saat)
  date        DateTime @default(now())

  // User Relation
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?   // AI'ın sohbete otomatik vereceği başlık
  
  // User Relation
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Message Relation
  messages  Message[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  role           String       // Sadece "USER" veya "AI" değerlerini alacak
  
  // Conversation Relation
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  title       String   // Örn: "First Login", "Study Streak"
  progress    Int      @default(0) // Yüzde veya sayısal ilerleme
  isUnlocked  Boolean  @default(false)

  // User Relation
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}