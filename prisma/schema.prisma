// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  avatarId      String    @default("atlas")
  createdAt     DateTime  @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
  updatedAt     DateTime  @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)

  studyPlans     StudyPlan[]
  sessions       StudySession[]
  conversations  Conversation[]
  flashcardDecks FlashcardDeck[]
  quizzes        Quiz[]
}

model StudyPlan {
  id          String  @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
  updatedAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
}

model StudySession {
  id              String   @id @default(uuid())
  userId          String
  actionType      String
  points          Int
  durationMinutes Int      @default(0)
  createdAt       DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id    String  @id @default(cuid())
  title String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages       Message[]
  flashcardDecks FlashcardDeck[]
  quizzes        Quiz[]

  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
  updatedAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
}

model Message {
  id      String @id @default(cuid())
  content String @db.Text
  role    String

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
}

model FlashcardDeck {
  id             String        @id @default(cuid())
  title          String
  sourceName     String?
  conversationId String?
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  flashcards     Flashcard[]
  createdAt      DateTime      @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
  updatedAt      DateTime      @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
}

model Flashcard {
  id        String        @id @default(cuid())
  frontText String
  backText  String
  deckId    String
  deck      FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model Quiz {
  id             String        @id @default(cuid())
  title          String
  score          Int?
  isCompleted    Boolean       @default(false)
  sourceName     String?
  conversationId String?
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  questions      Question[]
  createdAt      DateTime      @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
  updatedAt      DateTime      @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)
}

model Question {
  id            String @id @default(cuid())
  questionText  String
  options       Json
  correctAnswer String
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PendingRegistration {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamptz(3)

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String
  expires DateTime

  @@unique([email, token])
}
